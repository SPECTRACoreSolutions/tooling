# Railway Configuration Template
#
# This file configures Railway deployment settings for your service.
# Place this file at the root of your repository as: railway.json
#
# Documentation: https://docs.railway.app/reference/config-as-code

{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": null,
    "watchPatterns": [
      "**/*.py",
      "**/*.js",
      "**/*.ts",
      "requirements.txt",
      "package.json",
      "pyproject.toml"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "healthcheck": {
    "path": "/health",
    "timeout": 100,
    "interval": 30
  },
  "regions": [
    "us-west1"
  ]
}


