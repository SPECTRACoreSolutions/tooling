{
  "mcpServers": {
    "spectra-context": {
      "command": "python",
      "args": ["-m", "spectra_context_mcp.server", "--mode", "stdio"],
      "cwd": "__SPECTRA_ROOT__\\Core\\mcp-service",
      "env": {
        "LOG_LEVEL": "INFO"
      }
    },
    "Railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"],
      "env": {
        "ALLOWED_DIRECTORIES": "__SPECTRA_ROOT__"
      }
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "__GITHUB_PERSONAL_ACCESS_TOKEN__"
      }
    },
    "ms365": {
      "command": "npx",
      "args": ["-y", "@softeria/ms-365-mcp-server"]
    },
    "azure": {
      "command": "npx",
      "args": ["-y", "@azure/mcp-server"]
    },
    "atlassian": {
      "command": "npx",
      "args": ["-y", "@atlassian/mcp-server"],
      "env": {
        "ATLASSIAN_API_TOKEN": "__ATLASSIAN_API_TOKEN__",
        "ATLASSIAN_DOMAIN": "__ATLASSIAN_DOMAIN__"
      }
    },
    "cloudflare-dns": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server-dns-analytics"]
    }
  }
}
